{
  "openapi": "3.0.0",
  "info": {
    "title": "AI TripCraft API Docs",
    "version": "1.0.0",
    "description": "Production-ready backend API documentation for AI TripCraft – Smart AI Travel Itinerary Planner"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "admin"] },
          "profile": {
            "type": "object",
            "properties": {
              "firstName": { "type": "string" },
              "lastName": { "type": "string" },
              "phone": { "type": "string" },
              "avatarUrl": { "type": "string" }
            }
          }
        }
      },
      "Trip": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "destination": { "type": "string" },
          "country": { "type": "string" },
          "startDate": { "type": "string", "format": "date" },
          "numberOfDays": { "type": "integer" },
          "budget": { "type": "string", "enum": ["Budget", "Moderate", "Luxury"] },
          "numberOfTravelers": { "type": "integer" },
          "interests": { "type": "array", "items": { "type": "string" } },
          "transportPreference": { "type": "string" },
          "hotelPreference": { "type": "string" },
          "foodPreference": { "type": "string" },
          "tripType": { "type": "string", "enum": ["Solo", "Family", "Couple", "Friends", "Business"] },
          "isSaved": { "type": "boolean" },
          "estimatedBudgetBreakdown": {
            "type": "object",
            "properties": {
              "hotelCost": { "type": "number" },
              "foodCost": { "type": "number" },
              "transportCost": { "type": "number" },
              "attractionsCost": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "email", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created successfully" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate a user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Logged in successfully" }
        }
      }
    },
    "/api/trips": {
      "get": {
        "summary": "Get user trips (paginated, filtered, searched)",
        "tags": ["Trips"],
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "budget", "in": "query", "schema": { "type": "string" } },
          { "name": "tripType", "in": "query", "schema": { "type": "string" } },
          { "name": "duration", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Trips retrieved successfully" }
        }
      },
      "post": {
        "summary": "Create a new trip & generate AI itinerary",
        "tags": ["Trips"],
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["destination", "country", "startDate", "numberOfDays", "budget", "tripType"],
                "properties": {
                  "destination": { "type": "string" },
                  "country": { "type": "string" },
                  "startDate": { "type": "string", "format": "date" },
                  "numberOfDays": { "type": "integer" },
                  "budget": { "type": "string" },
                  "tripType": { "type": "string" },
                  "numberOfTravelers": { "type": "integer" },
                  "interests": { "type": "array", "items": { "type": "string" } },
                  "transportPreference": { "type": "string" },
                  "hotelPreference": { "type": "string" },
                  "foodPreference": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Trip and Itinerary generated successfully" }
        }
      }
    },
    "/api/admin/stats": {
      "get": {
        "summary": "Retrieve dashboard analytics data",
        "tags": ["Admin & Analytics"],
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Statistics fetched" }
        }
      }
    }
  }
}
